# NasTech-Agent Configuration Template
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to git!
# 
# Usage:
#   cp .env.template .env
#   nano .env  # Edit with your credentials

# ============================================================================
# REQUIRED: Telegram Configuration
# ============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# ============================================================================
# OPTIONAL: AI Provider API Keys
# ============================================================================
# Groq (https://console.groq.com)
GROQ_API_KEY=

# OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=

# Anthropic/Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=

# Google Gemini (https://ai.google.dev)
GEMINI_API_KEY=

# ============================================================================
# OPTIONAL: GitHub Configuration
# ============================================================================
GITHUB_TOKEN=
GITHUB_USERNAME=

# ============================================================================
# OPTIONAL: Advanced Configuration
# ============================================================================
# Database
DATABASE_URL=sqlite:///nastech.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=~/.nastech/logs/nastech.log

# Behavior
DEBUG=false
DRY_RUN=false
QUIET_MODE=false

# ============================================================================
# OPTIONAL: Third-party Service Credentials
# ============================================================================
# Cloudflare API
CLOUDFLARE_API_KEY=
CLOUDFLARE_EMAIL=

# AWS (if using AWS services)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ============================================================================
# DO NOT EDIT BELOW - System Variables
# ============================================================================
NASTECH_HOME=~/.nastech
PYTHONUNBUFFERED=1
