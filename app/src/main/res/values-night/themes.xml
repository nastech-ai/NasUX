<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- NasUX AMOLED Black Night Theme — pure #000000 sidebar, NasTech teal accent -->
    <style name="Theme.NasUXActivity.DayNight.NoActionBar" parent="Theme.NasUXApp.DayNight.NoActionBar">
        <item name="colorPrimary">@color/amoled_bg</item>
        <item name="colorPrimaryVariant">@color/amoled_bg</item>
        <item name="colorSecondary">@color/nastech_accent</item>
        <item name="colorOnSecondary">@color/amoled_bg</item>

        <item name="android:windowBackground">@color/amoled_bg</item>
        <item name="android:colorBackground">@color/amoled_bg</item>

        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>

        <item name="buttonBarButtonStyle">@style/NasUXActivity.Drawer.ButtonBarStyle.Dark</item>
        <item name="nasuxActivityDrawerBackground">@color/sidebar_bg</item>
        <item name="nasuxActivityDrawerImageTint">@color/nastech_accent</item>

        <item name="extraKeysButtonTextColor">@color/extra_keys_text</item>
        <item name="extraKeysButtonActiveTextColor">@color/nastech_accent</item>
        <item name="extraKeysButtonBackgroundColor">@color/extra_keys_bg</item>
        <item name="extraKeysButtonActiveBackgroundColor">@color/extra_keys_active_bg</item>
    </style>
</resources>
