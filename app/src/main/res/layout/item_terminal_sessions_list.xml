<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/session_background_selected"
    android:paddingStart="14dp"
    android:paddingEnd="8dp">

    <!-- Active session indicator dot -->
    <View
        android:id="@+id/session_active_indicator"
        android:layout_width="4dp"
        android:layout_height="4dp"
        android:layout_marginEnd="10dp"
        android:background="@color/nastech_accent"
        android:visibility="gone" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/session_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:singleLine="true"
        android:gravity="start|center_vertical"
        android:textSize="13sp"
        android:textColor="@color/session_text"
        android:fontFamily="@font/source_code_pro" />
</LinearLayout>
