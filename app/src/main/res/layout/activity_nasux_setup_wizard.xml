<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/amoled_bg"
    android:fitsSystemWindows="true">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/toolbar_bg">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NasTech AI Setup"
            android:textColor="@color/nastech_accent"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/source_code_pro" />

        <TextView
            android:id="@+id/wizard_step_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 / 4"
            android:textColor="@color/text_disabled"
            android:textSize="12sp"
            android:fontFamily="@font/source_code_pro" />
    </LinearLayout>

    <!-- Step progress dots -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:orientation="horizontal">
        <View android:id="@+id/step_bar_1"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:background="@color/nastech_accent"/>
        <View android:id="@+id/step_bar_2"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:background="@color/divider"/>
        <View android:id="@+id/step_bar_3"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:background="@color/divider"/>
        <View android:id="@+id/step_bar_4"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:background="@color/divider"/>
    </LinearLayout>

    <!-- Step content area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/amoled_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Step icon / title -->
            <TextView
                android:id="@+id/wizard_step_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◈"
                android:textColor="@color/nastech_accent"
                android:textSize="36sp"
                android:fontFamily="@font/source_code_pro"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/wizard_step_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome to NasUX"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/source_code_pro"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/wizard_step_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Full Linux + NasTech AI on your Android"
                android:textColor="@color/nastech_accent"
                android:textSize="13sp"
                android:fontFamily="@font/source_code_pro"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/wizard_step_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/source_code_pro"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp" />

            <!-- Terminal-style log output -->
            <ScrollView
                android:id="@+id/wizard_log_scroll"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:visibility="gone"
                android:background="@color/surface_1"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/wizard_log_output"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text=""
                    android:textColor="@color/terminal_green"
                    android:textSize="11sp"
                    android:fontFamily="@font/source_code_pro"
                    android:lineSpacingExtra="2dp" />
            </ScrollView>

            <!-- Progress bar for install steps -->
            <LinearLayout
                android:id="@+id/wizard_progress_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <ProgressBar
                    android:id="@+id/wizard_progress"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/nastech_accent"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/wizard_progress_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Installing…"
                    android:textColor="@color/nastech_accent"
                    android:textSize="11sp"
                    android:fontFamily="@font/source_code_pro"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/toolbar_bg">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/wizard_skip_btn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Skip"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/source_code_pro"
            android:strokeColor="@color/divider"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/wizard_next_btn"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Next →"
            android:textColor="@color/amoled_bg"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/source_code_pro"
            android:backgroundTint="@color/nastech_accent" />

    </LinearLayout>

</LinearLayout>
