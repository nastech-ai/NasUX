<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- NasUX AMOLED Black Base Night Themes -->

    <style name="Theme.BaseActivity.DayNight.DarkActionBar" parent="Theme.MaterialComponents">
        <item name="colorPrimary">@color/nastech_accent</item>
        <item name="colorPrimaryVariant">@color/nastech_accent_dark</item>
        <item name="colorOnPrimary">@color/amoled_bg</item>

        <item name="colorSecondary">@color/nastech_blue</item>
        <item name="colorSecondaryVariant">@color/surface_1</item>
        <item name="colorOnSecondary">@color/amoled_bg</item>

        <item name="android:statusBarColor" tools:targetApi="l">@color/amoled_bg</item>
        <item name="colorPrimaryDark" tools:targetApi="l">@color/amoled_bg</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorLink">@color/blue_link_dark</item>

        <item name="android:colorBackground">@color/amoled_bg</item>
        <item name="android:windowBackground">@color/amoled_bg</item>
    </style>

    <style name="Theme.BaseActivity.DayNight.NoActionBar" parent="Theme.BaseActivity.DayNight.DarkActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- AMOLED Black Dialog -->
    <style name="ThemeOverlay.BaseDialog.DayNight" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/nastech_accent</item>
        <item name="colorPrimaryVariant">@color/nastech_accent_dark</item>
        <item name="colorOnPrimary">@color/amoled_bg</item>

        <item name="colorSecondary">@color/nastech_blue</item>
        <item name="colorSecondaryVariant">@color/surface_1</item>
        <item name="colorOnSecondary">@color/amoled_bg</item>

        <item name="colorSurface">@color/surface_1</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <item name="materialAlertDialogTitlePanelStyle">@style/BaseDialog.Title.Panel</item>
        <item name="materialAlertDialogBodyTextStyle">@style/BaseDialog.Message.Text.Dark</item>
    </style>
</resources>
