#!/usr/bin/env python3
"""
NasTech Agent CLI — NasUX / Powered by NasTech AI
Single global entrypoint for all `nastech` commands.

Self-maintaining features:
  - Auto-installs missing dependencies on first run
  - Offline safe: skips network ops when no internet
  - nastech update: safe semver-aware updates
  - nastech --debug / --verbose: full boot trace
  - nastech --help: dynamic command list (or fallback if not installed)

Boot steps (this wrapper):
  1. Windows UTF-8 bootstrap (no-op on Android/POSIX)
  2. Python 3.11+ guard
  3. Project root → sys.path
  4. Venv auto-detection + activation
  5. Dependency self-heal (first run or missing packages)
  6. Route to nastech_cli.main or structured fallback
"""

from __future__ import annotations

import os
import sys
import time

# ── 1. Windows UTF-8 bootstrap ────────────────────────────────────────────────
try:
    import nastech_bootstrap  # noqa: F401
except ModuleNotFoundError:
    pass

# ── 2. Project root → sys.path ───────────────────────────────────────────────
_SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
if _SCRIPT_DIR not in sys.path:
    sys.path.insert(0, _SCRIPT_DIR)

_BOOT_START = time.monotonic()

# ── 3. Parse flags early (before argparse, so boot logs can appear) ───────────
_argv = sys.argv[1:]
_DEBUG   = "--debug" in _argv or "--verbose" in _argv or "-v" in _argv
_HELP    = "--help" in _argv or "-h" in _argv or not _argv
_VERSION = "--version" in _argv or "-V" in _argv
_UPDATE  = _argv[:1] == ["update"]
_DOCTOR  = _argv[:1] == ["doctor"]

# ── 4. Colors ─────────────────────────────────────────────────────────────────
_TTY = sys.stderr.isatty()
GRN  = "\033[0;32m" if _TTY else ""
YEL  = "\033[0;33m" if _TTY else ""
CYN  = "\033[0;36m" if _TTY else ""
RED  = "\033[0;31m" if _TTY else ""
BLD  = "\033[1m"    if _TTY else ""
NC   = "\033[0m"    if _TTY else ""


def _ms() -> str:
    return f"{int((time.monotonic() - _BOOT_START) * 1000)}ms"


def _boot(msg: str) -> None:
    if _DEBUG:
        print(f"{CYN}[BOOT {_ms()}]{NC} {msg}", file=sys.stderr, flush=True)


def _ok(msg: str) -> None:
    print(f"{GRN}[OK]{NC}   {msg}", file=sys.stderr, flush=True)


def _warn(msg: str) -> None:
    print(f"{YEL}[WARN]{NC} {msg}", file=sys.stderr, flush=True)


def _err(msg: str) -> None:
    print(f"{RED}[ERROR]{NC} {msg}", file=sys.stderr, flush=True)


# ── 5. Python version guard ───────────────────────────────────────────────────
if sys.version_info < (3, 11):
    _err(
        f"NasTech requires Python 3.11+. "
        f"You have {sys.version_info.major}.{sys.version_info.minor}."
    )
    _err("NasUX (Kali): apt install python3 python3-pip   |   Desktop: python.org")
    sys.exit(1)

_boot(f"Python {sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}")

# ── 6. Venv auto-activation ───────────────────────────────────────────────────

def _activate_venv() -> bool:
    if os.environ.get("VIRTUAL_ENV"):
        _boot("Already in venv")
        return True
    nastech_home = os.environ.get("NASTECH_HOME", os.path.join(os.path.expanduser("~"), ".nastech"))
    candidates = [
        os.path.join(nastech_home, "NasTech-Agent", "venv"),
        os.path.join(_SCRIPT_DIR, ".venv"),
        os.path.join(_SCRIPT_DIR, "venv"),
    ]
    for venv_dir in candidates:
        lib_dir = os.path.join(venv_dir, "lib")
        if not os.path.isdir(lib_dir):
            continue
        try:
            for entry in os.listdir(lib_dir):
                if entry.startswith("python"):
                    site = os.path.join(lib_dir, entry, "site-packages")
                    if os.path.isdir(site):
                        if site not in sys.path:
                            sys.path.insert(0, site)
                        venv_bin = os.path.join(venv_dir, "bin")
                        os.environ["VIRTUAL_ENV"] = venv_dir
                        os.environ["PATH"] = venv_bin + os.pathsep + os.environ.get("PATH", "")
                        _boot(f"Venv activated: {venv_dir}")
                        return True
        except OSError:
            continue
    _boot("No venv found — using system Python")
    return False


_activate_venv()

# ── 7. Dependency self-heal ───────────────────────────────────────────────────

def _run_dep_check() -> None:
    """
    Run dependency check on first boot or when packages are missing.
    Skipped if lock file indicates first-run was already completed AND
    all core imports succeed (fast path).
    """
    # Fast path: try importing key module — if it works, deps are fine
    try:
        import importlib
        importlib.import_module("click")
        importlib.import_module("fastapi")
        _boot("Core deps present — skipping dep check")
        return
    except ImportError:
        pass

    _boot("Core deps missing — running dependency bootstrap...")
    try:
        from nastech_deps import DependencyManager
        dm = DependencyManager(
            debug=_DEBUG,
            nastech_home=_get_nastech_home(),
        )
        dm.run_boot_check()
    except ImportError:
        _warn("nastech_deps not found — running pip install fallback")
        _pip_fallback_install()
    except Exception as exc:
        _warn(f"Dep check failed: {exc} — continuing anyway")


def _get_nastech_home():
    from pathlib import Path
    return Path(os.environ.get("NASTECH_HOME", str(os.path.join(os.path.expanduser("~"), ".nastech"))))


def _pip_fallback_install() -> None:
    """Last-resort pip install of bare minimum packages."""
    import subprocess
    minimal = ["click", "fastapi", "uvicorn", "pyyaml", "httpx", "rich"]
    try:
        subprocess.run(
            [sys.executable, "-m", "pip", "install", "--quiet", "--no-input"] + minimal,
            timeout=120,
            check=False,
        )
        _boot("Fallback pip install completed")
    except Exception as exc:
        _warn(f"Fallback pip install failed: {exc}")


# ── 8. Structured fallback --help (when nastech_cli is not installed) ─────────

_FALLBACK_HELP = f"""{BLD}NasUX — Powered by NasTech AI{NC}

{CYN}Usage:{NC}  nastech [OPTIONS] COMMAND [ARGS]

{CYN}Core commands:{NC}
  chat          Start interactive AI chat
  setup         Run setup wizard (choose AI provider + model)
  dashboard     Open web dashboard (http://127.0.0.1:9119)
  gateway       Start gateway service
  acp           Start ACP stdio adapter (for IDE integration)
  cron          Run cron scheduler
  update        Check and install safe updates
  doctor        Self-diagnostic health check
  logs          View agent logs
  version       Print version information

{CYN}Options:{NC}
  --help, -h            Show this help
  --version, -V         Print version and exit
  --debug, --verbose    Enable verbose boot logging

{YEL}NasTech CLI is not installed yet.{NC}
Install it with:

  bash ~/nastech-agent/install.sh

{CYN}On Kali NetHunter (proot-distro) — install Python first if needed:{NC}

  apt update && apt install -y python3 python3-pip python3-venv
  bash ~/nastech-agent/install.sh

Then configure and start:
  nastech setup
  nastech chat
"""

# ── 9. Attempt to load nastech_cli ────────────────────────────────────────────

def _load_nastech_cli():
    """Try to import nastech_cli.main. Returns (main_fn, version) or (None, err)."""
    try:
        from nastech_cli.main import main as _fn
        try:
            from nastech_cli import __version__ as _v
        except Exception:
            _v = "unknown"
        return _fn, _v
    except ModuleNotFoundError:
        return None, "not-installed"
    except ImportError as exc:
        return None, str(exc)
    except Exception as exc:
        return None, str(exc)


# ── MAIN ─────────────────────────────────────────────────────────────────────

def main() -> None:
    _boot("Loading modules...")

    # ── Handle `nastech update` before loading nastech_cli ───────────────────
    if _UPDATE:
        try:
            from nastech_deps import DependencyManager
            import argparse
            p = argparse.ArgumentParser(add_help=False)
            p.add_argument("--debug", "-v", "--verbose", action="store_true")
            p.add_argument("--yes", "-y", action="store_true", dest="assume_yes")
            p.add_argument("--force", action="store_true")
            known, _ = p.parse_known_args()
            dm = DependencyManager(
                debug=known.debug or _DEBUG,
                nastech_home=_get_nastech_home(),
                assume_yes=known.assume_yes,
            )
            rc = dm.run_update(force_major=known.force)
            sys.exit(rc)
        except ImportError:
            _err("nastech_deps not found — cannot run update")
            sys.exit(1)
        except Exception as exc:
            _err(f"Update failed: {exc}")
            if _DEBUG:
                import traceback; traceback.print_exc()
            sys.exit(1)

    # ── Handle `nastech doctor` ───────────────────────────────────────────────
    if _DOCTOR:
        try:
            from nastech_deps import DependencyManager
            dm = DependencyManager(debug=_DEBUG, nastech_home=_get_nastech_home())
            sys.exit(dm.run_doctor())
        except ImportError:
            _err("nastech_deps not found — cannot run doctor")
            sys.exit(1)

    # ── Dependency self-heal (skipped if deps already present) ───────────────
    if _DEBUG:
        os.environ.setdefault("NASTECH_DEBUG", "1")
        os.environ.setdefault("NASTECH_LOG_LEVEL", "DEBUG")

    _run_dep_check()

    # ── Try loading nastech_cli ───────────────────────────────────────────────
    main_fn, meta = _load_nastech_cli()

    if main_fn is None:
        if _HELP:
            print(_FALLBACK_HELP)
            sys.exit(0)
        _err("NasTech CLI not installed.")
        _err(f"Run:  bash {_SCRIPT_DIR}/install.sh")
        if meta and meta not in ("not-installed", ""):
            _err(f"Detail: {meta}")
        sys.exit(1)

    _boot(f"nastech_cli loaded (version: {meta})")
    _boot("Registering command router...")

    if _DEBUG:
        _ok(f"NasUX Ready (startup: {_ms()})")

    # ── Delegate to nastech_cli ───────────────────────────────────────────────
    try:
        main_fn()
    except KeyboardInterrupt:
        print("", file=sys.stderr)
        sys.exit(0)
    except SystemExit:
        raise
    except Exception as exc:
        _err(f"NasTech crashed: {exc}")
        if _DEBUG:
            import traceback; traceback.print_exc()
        else:
            _err("Re-run with  nastech --debug  for full traceback")
        sys.exit(1)


if __name__ == "__main__":
    main()
