<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/rounded_dialog_bg">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="#44FFFFFF"
        android:layout_marginEnd="0dp" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Code Preview"
            android:textColor="@color/nastech_accent"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="@font/source_code_pro"
            android:letterSpacing="0.04" />

        <!-- Copy button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/preview_btn_copy"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Copy"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginEnd="6dp"
            android:fontFamily="@font/source_code_pro"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:backgroundTint="@color/surface_2"
            app:cornerRadius="8dp"
            app:elevation="0dp" />

        <!-- Share button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/preview_btn_share"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Share"
            android:textColor="@color/nastech_accent"
            android:textSize="12sp"
            android:fontFamily="@font/source_code_pro"
            app:strokeColor="@color/border_accent"
            app:strokeWidth="1dp"
            app:backgroundTint="@color/surface_2"
            app:cornerRadius="8dp"
            app:elevation="0dp" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/border_accent" />

    <!-- Language / mode selector chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_auto"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Auto"
                android:textColor="@color/amoled_bg"
                android:textSize="11sp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/ai_chip_primary_bg"
                android:fontFamily="@font/source_code_pro"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chip_bash"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="bash"
                android:textColor="@color/nastech_accent"
                android:textSize="11sp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/ai_chip_bg"
                android:fontFamily="@font/source_code_pro"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chip_python"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="python"
                android:textColor="@color/nastech_accent"
                android:textSize="11sp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/ai_chip_bg"
                android:fontFamily="@font/source_code_pro"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chip_js"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="javascript"
                android:textColor="@color/nastech_accent"
                android:textSize="11sp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/ai_chip_bg"
                android:fontFamily="@font/source_code_pro"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chip_markdown"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="markdown"
                android:textColor="@color/nastech_accent"
                android:textSize="11sp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/ai_chip_bg"
                android:fontFamily="@font/source_code_pro"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Input area -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/preview_input_layout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="6dp"
        app:boxStrokeColor="@color/border_accent"
        app:boxBackgroundColor="@color/surface_2"
        app:hintTextColor="@color/text_disabled"
        app:boxCornerRadiusTopStart="10dp"
        app:boxCornerRadiusTopEnd="10dp"
        app:boxCornerRadiusBottomStart="10dp"
        app:boxCornerRadiusBottomEnd="10dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/preview_input"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="Paste code or markdown here…"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:textSize="12sp"
            android:fontFamily="@font/source_code_pro"
            android:inputType="textMultiLine|textNoSuggestions"
            android:gravity="top|start"
            android:background="@android:color/transparent" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Render button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/preview_btn_render"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="10dp"
        android:text="Render Preview ▶"
        android:textColor="@color/amoled_bg"
        android:textStyle="bold"
        android:textSize="13sp"
        android:fontFamily="@font/source_code_pro"
        app:backgroundTint="@color/nastech_accent"
        app:cornerRadius="10dp"
        app:elevation="0dp" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/border_accent" />

    <!-- Rendered markdown output -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical"
        android:fadingEdge="vertical"
        android:fadingEdgeLength="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Rendered markdown output label -->
            <TextView
                android:id="@+id/preview_output_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OUTPUT"
                android:textColor="@color/text_disabled"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:paddingBottom="8dp"
                android:fontFamily="@font/source_code_pro"
                android:visibility="gone" />

            <TextView
                android:id="@+id/preview_output"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/source_code_pro"
                android:lineSpacingExtra="4dp"
                android:textIsSelectable="true"
                android:visibility="gone" />

            <!-- Empty state -->
            <TextView
                android:id="@+id/preview_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Paste code or markdown above, then tap Render Preview"
                android:textColor="@color/text_disabled"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingTop="32dp"
                android:fontFamily="@font/source_code_pro" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
